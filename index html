    <div class="container">
        
        <main>
            <div id="home-tab" class="tab-content active-tab class posts-section">
                <h2>Artigos em Destaque</h2>

                <article class="post-card">
                    <div class="post-content">
                        <span class="post-category">Práticas Sustentáveis</span>
                        <h3 class="post-title">O que é o Agro Sustentável e por que ele é o futuro?</h3>
                        <div class="post-meta">Postado por Equipe AgroSustentável</div>
