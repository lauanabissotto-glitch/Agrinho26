    <script>
        // Função 1: Alternar entre as abas do Menu Superior
        const links = document.querySelectorAll('.nav-link');
        const tabs = document.querySelectorAll('.tab-content');

        links.forEach(link => {
            link.addEventListener('click', () => {
                // Remove a classe ativa de todos os botões do menu
                links.forEach(l => l.classList.remove('active'));
                // Remove a classe ativa de todas as abas
                tabs.forEach(t => t.classList.remove('active-tab'));

                // Adiciona o destaque no link clicado
                link.classList.add('active');
                // Mostra a aba correspondente
                const targetTab = link.getAttribute('data-tab');
                document.getElementById(targetTab).classList.add('active-tab');
            });
        });

        // Função 2: Expandir/Recolher os artigos
        function togglePost(button) {
            const card = button.parentElement;
            const fullText = card.querySelector('.full-text');
            
            if (fullText.style.display === 'block') {
                fullText.style.display = 'none';
                button.textContent = 'Ler Artigo Completo →';
            } else {
                fullText.style.display = 'block';
                button.textContent = 'Fechar Artigo ←';
            }
        }
    </script>
